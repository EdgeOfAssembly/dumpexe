icon_dummy.asm
                                ; icon_dummy.asm — ICON terrain stub (UASM)  v3
                                ;
                                ; Goal: same draw path as ICON1 (map index → stamp → B800), not file→PNG.
                                ; After this is solid, a host PNG tool can reuse the same blit rules.
                                ;
                                ; Load order:
                                ;   1) STAMPS.BIN + MAPRT.BIN  (optional runtime dumps → near byte-id vs live ICON)
                                ;   2) else BA.DAT [+BB.DAT] + LA.MAP  (on-disk; BA skip leading 5Ah → char,attr)
                                ;
                                ; Draw (ICON1-faithful):
                                ;   clear B800 to 00,00
                                ;   for strip_row 0..3, stamp_col 0..18:
                                ;     id = map[(cam_x+sc)*100 + (cam_y+sr)]
                                ;     blit 2×6 cells at (col=1+sc*2, row=2+sr*6) from bank+id*24 (char,attr)
                                ;   half-stamp at map x=cam_x+19 → column 39 only (live B800 right edge)
                                ;
                                ; Keys: arrows camera, R reset, ESC quit
                                ;
                                ; Build:  uasm -bin -Fo icon_dummy.com icon_dummy.asm
                                ; Run:    from ICON/ (data files beside COM)
                                ;
                                .8086
                                .model tiny
                                .code
 00000100                        start:
00000100  E9D701                        jmp     main

                                ; ---------------------------------------------------------------------------
 = 64                           MAP_STRIDE      equ     100
 = 18                           STAMP_BYTES     equ     24
 = C0                           STAMP_COUNT     equ     192             ; 96+96; ids mod this
 = 13                           VIEW_W          equ     19              ; full 2-cell stamps (ICON i=0..12h)
 = 4                            VIEW_H          equ     4
 = 1                            COL0            equ     1
 = 2                            ROW0            equ     2
 = 7                            CAM_X0_FILE     equ     7               ; cold start on LA.MAP
 = 4B                           CAM_Y0_FILE     equ     75
 = 0                            CAM_X0_RT       equ     0               ; runtime map already scrolled
 = 0                            CAM_Y0_RT       equ     0

 = 900                          BA_SIZE         equ     2304
 = 900                          BB_SIZE         equ     2304
 = 1200                         BANK_SIZE       equ     BA_SIZE + BB_SIZE
 = F00                          MAP_SIZE        equ     3840

                                ; ---------------------------------------------------------------------------
00000103  49434F4E2064756D6D    msg_boot        db      'ICON dummy v3: draw path + optional RT dumps.',0Dh,0Ah,'$'
00000133  4C6F61646564205354    msg_rt          db      'Loaded STAMPS.BIN + MAPRT.BIN (parity mode).',0Dh,0Ah,'$'
00000162  4C6F61646564204241    msg_file        db      'Loaded BA/BB + LA.MAP (file mode, BA bake).',0Dh,0Ah,'$'
00000190  464342206F70656E20    msg_no_ba       db      'FCB open BA.DAT failed.',0Dh,0Ah,'$'
000001AA  464342206F70656E20    msg_no_map      db      'FCB open LA.MAP / MAPRT.BIN failed.',0Dh,0Ah,'$'
000001D0  0D0A49434F4E206475    msg_bye         db      0Dh,0Ah,'ICON dummy exit. mode was: $'
000001EE  706172697479202853    msg_bye_rt      db      'parity (STAMPS+MAPRT)',0Dh,0Ah,'$'
00000206  66696C65202842412F    msg_bye_file    db      'file (BA/BB+LA.MAP)',0Dh,0Ah,'$'

                                ; FCB: drive, 8.3 name, 25 reserved (UASM: split db lines)
0000021C                        fcb_stamps:
0000021C  00                            db      0
0000021D  5354414D50532020              db      'STAMPS  '
00000225  42494E                        db      'BIN'
00000228  000000000000000000            db      25 dup (0)
00000241                        fcb_maprt:
00000241  00                            db      0
00000242  4D41505254202020              db      'MAPRT   '
0000024A  42494E                        db      'BIN'
0000024D  000000000000000000            db      25 dup (0)
00000266                        fcb_ba:
00000266  00                            db      0
00000267  4241202020202020              db      'BA      '
0000026F  444154                        db      'DAT'
00000272  000000000000000000            db      25 dup (0)
0000028B                        fcb_bb:
0000028B  00                            db      0
0000028C  4242202020202020              db      'BB      '
00000294  444154                        db      'DAT'
00000297  000000000000000000            db      25 dup (0)
000002B0                        fcb_map:
000002B0  00                            db      0
000002B1  4C41202020202020              db      'LA      '
000002B9  4D4150                        db      'MAP'
000002BC  000000000000000000            db      25 dup (0)

000002D5  0700                  cam_x   dw      CAM_X0_FILE
000002D7  4B00                  cam_y   dw      CAM_Y0_FILE
000002D9  00                    mode_rt db      0                       ; 1 = STAMPS+MAPRT

                                ; ---------------------------------------------------------------------------
000002DA                        main:
000002DA  0E                            push    cs
000002DB  1F                            pop     ds
000002DC  0E                            push    cs
000002DD  07                            pop     es

000002DE  BA0000                        mov     dx, offset msg_boot
000002E1  B409                          mov     ah, 09h
000002E3  CD21                          int     21h

                                        ; --- try parity dumps first ---
000002E5  C606000000                    mov     byte ptr mode_rt, 0
000002EA  BA0000                        mov     dx, offset fcb_stamps
000002ED  E89B01                        call    fcb_open
000002F0  723B                          jc      file_mode
000002F2  BA0000                        mov     dx, offset fcb_stamps
000002F5  BB0000                        mov     bx, offset bank_buf
000002F8  B92400                        mov     cx, BANK_SIZE / 128
000002FB  E8A901                        call    fcb_read_all

000002FE  BA0000                        mov     dx, offset fcb_maprt
00000301  E88701                        call    fcb_open
00000304  7227                          jc      file_mode_after_stamps
00000306  BA0000                        mov     dx, offset fcb_maprt
00000309  BB0000                        mov     bx, offset map_buf
0000030C  B91E00                        mov     cx, MAP_SIZE / 128
0000030F  E89501                        call    fcb_read_all

00000312  C606000001                    mov     byte ptr mode_rt, 1
00000317  C70600000000                  mov     word ptr cam_x, CAM_X0_RT
0000031D  C70600000000                  mov     word ptr cam_y, CAM_Y0_RT
00000323  BA0000                        mov     dx, offset msg_rt
00000326  B409                          mov     ah, 09h
00000328  CD21                          int     21h
0000032A  E9A300                        jmp     go_video

0000032D                        file_mode_after_stamps:
                                        ; STAMPS without MAPRT → fall through to full file mode
0000032D                        file_mode:
                                        ; --- BA.DAT required ---
0000032D  BA0000                        mov     dx, offset fcb_ba
00000330  E85801                        call    fcb_open
00000333  726C                          jc      err_ba
00000335  BA0000                        mov     dx, offset fcb_ba
00000338  BB0000                        mov     bx, offset bank_buf
0000033B  B91200                        mov     cx, BA_SIZE / 128
0000033E  E86601                        call    fcb_read_all
00000341  E87700                        call    bake_ba                 ; drop 5Ah; body is char,attr

                                        ; --- BB.DAT optional ---
00000344  BA0000                        mov     dx, offset fcb_bb
00000347  E84101                        call    fcb_open
0000034A  7222                          jc      bb_zero
0000034C  BA0000                        mov     dx, offset fcb_bb
0000034F  BB0009                        mov     bx, offset bank_buf + BA_SIZE
00000352  B91200                        mov     cx, BB_SIZE / 128
00000355  E84F01                        call    fcb_read_all
                                        ; bake BB the same way (leading 5Ah)
00000358  56                            push    si
00000359  57                            push    di
0000035A  51                            push    cx
0000035B  BE0109                        mov     si, offset bank_buf + BA_SIZE + 1
0000035E  BF0009                        mov     di, offset bank_buf + BA_SIZE
00000361  B9FF08                        mov     cx, BB_SIZE - 1
00000364  F3A4                          rep     movsb
00000366  C60500                        mov     byte ptr [di], 0
00000369  59                            pop     cx
0000036A  5F                            pop     di
0000036B  5E                            pop     si
0000036C  EB0A                          jmp     load_map
0000036E                        bb_zero:
0000036E  BF0009                        mov     di, offset bank_buf + BA_SIZE
00000371  B90009                        mov     cx, BB_SIZE
00000374  32C0                          xor     al, al
00000376  F3AA                          rep     stosb

00000378                        load_map:
00000378  BA0000                        mov     dx, offset fcb_map
0000037B  E80D01                        call    fcb_open
0000037E  722E                          jc      err_map
00000380  BA0000                        mov     dx, offset fcb_map
00000383  BB0000                        mov     bx, offset map_buf
00000386  B91E00                        mov     cx, MAP_SIZE / 128
00000389  E81B01                        call    fcb_read_all

0000038C  C70600000700                  mov     word ptr cam_x, CAM_X0_FILE
00000392  C70600004B00                  mov     word ptr cam_y, CAM_Y0_FILE
00000398  BA0000                        mov     dx, offset msg_file
0000039B  B409                          mov     ah, 09h
0000039D  CD21                          int     21h
0000039F  EB2F                          jmp     go_video

000003A1                        err_ba:
000003A1  E8DF00                        call    fail_mode3
000003A4  BA0000                        mov     dx, offset msg_no_ba
000003A7  B409                          mov     ah, 09h
000003A9  CD21                          int     21h
000003AB  E9D000                        jmp     exit_err
000003AE                        err_map:
000003AE  E8D200                        call    fail_mode3
000003B1  BA0000                        mov     dx, offset msg_no_map
000003B4  B409                          mov     ah, 09h
000003B6  CD21                          int     21h
000003B8  E9C300                        jmp     exit_err

                                ; ---------------------------------------------------------------------------
                                ; bake_ba: BA.DAT on disk is 5Ah + char,attr stream (live DS:207A stamps 0..90).
                                ; Shift bank_buf left by 1 within the BA half.
                                ; ---------------------------------------------------------------------------
000003BB                        bake_ba:
000003BB  56                            push    si
000003BC  57                            push    di
000003BD  51                            push    cx
000003BE  BE0100                        mov     si, offset bank_buf + 1
000003C1  BF0000                        mov     di, offset bank_buf
000003C4  B9FF08                        mov     cx, BA_SIZE - 1
000003C7  F3A4                          rep     movsb
000003C9  C60500                        mov     byte ptr [di], 0        ; pad last
000003CC  59                            pop     cx
000003CD  5F                            pop     di
000003CE  5E                            pop     si
000003CF  C3                            ret

                                ; ---------------------------------------------------------------------------
000003D0                        go_video:
000003D0  B80100                        mov     ax, 0001h               ; mode 01h 40×25
000003D3  CD10                          int     10h

000003D5                        main_loop:
000003D5  E8E600                        call    clear_b800
000003D8  E8F800                        call    blit_viewport

000003DB  32E4                          xor     ah, ah
000003DD  CD16                          int     16h
000003DF  80FC01                        cmp     ah, 01h                 ; ESC
000003E2  7476                          je      do_exit
000003E4  80FC48                        cmp     ah, 48h
000003E7  7419                          je      key_up
000003E9  80FC50                        cmp     ah, 50h
000003EC  7421                          je      key_dn
000003EE  80FC4B                        cmp     ah, 4Bh
000003F1  7429                          je      key_lf
000003F3  80FC4D                        cmp     ah, 4Dh
000003F6  7431                          je      key_rt
000003F8  3C72                          cmp     al, 'r'
000003FA  743A                          je      key_rst
000003FC  3C52                          cmp     al, 'R'
000003FE  7436                          je      key_rst
00000400  EBD3                          jmp     main_loop

00000402                        key_up:
00000402  833E000000                    cmp     word ptr cam_y, 0
00000407  74CC                          je      main_loop
00000409  FF0E0000                      dec     word ptr cam_y
0000040D  EBC6                          jmp     main_loop
0000040F                        key_dn:
0000040F  833E000060                    cmp     word ptr cam_y, 96
00000414  73BF                          jae     main_loop
