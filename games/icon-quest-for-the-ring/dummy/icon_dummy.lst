000004BE  06                            push    es
000004BF  57                            push    di
000004C0  51                            push    cx
000004C1  B800B8                        mov     ax, 0B800h
000004C4  8EC0                          mov     es, ax
000004C6  33FF                          xor     di, di
000004C8  B9E803                        mov     cx, 40*25
000004CB  33C0                          xor     ax, ax
000004CD  F3AB                          rep     stosw
000004CF  59                            pop     cx
000004D0  5F                            pop     di
000004D1  07                            pop     es
000004D2  C3                            ret

                                ; ---------------------------------------------------------------------------
                                ; blit_viewport — ICON1 grid + col-39 half stamp
                                ; bank_buf cells are already char,attr (runtime order)
                                ; ---------------------------------------------------------------------------
000004D3                        blit_viewport:
000004D3  06                            push    es
000004D4  B800B8                        mov     ax, 0B800h
000004D7  8EC0                          mov     es, ax

000004D9  33ED                          xor     bp, bp                  ; sr
000004DB                        blit_sr:
