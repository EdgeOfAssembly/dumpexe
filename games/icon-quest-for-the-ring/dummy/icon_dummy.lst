000004DE  7203E9E300                    jae     blit_done

000004E3  33F6                          xor     si, si                  ; sc
000004E5                        blit_sc:
000004E5  83FE13                        cmp     si, VIEW_W
000004E8  7376                          jae     blit_half               ; after 19 full stamps → col 39

                                        ; map index = (cam_x+sc)*100 + (cam_y+sr)
000004EA  8BC6                          mov     ax, si
000004EC  03060000                      add     ax, cam_x
000004F0  BB6400                        mov     bx, MAP_STRIDE
000004F3  F7E3                          mul     bx                      ; DX:AX  (save DX around later mul)
000004F5  03060000                      add     ax, cam_y
