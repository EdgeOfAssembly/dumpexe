0000041A  EBB9                          jmp     main_loop
0000041C                        key_lf:
0000041C  833E000000                    cmp     word ptr cam_x, 0
00000421  74B2                          je      main_loop
00000423  FF0E0000                      dec     word ptr cam_x
00000427  EBAC                          jmp     main_loop
00000429                        key_rt:
00000429  833E000012                    cmp     word ptr cam_x, 18      ; room for sc 0..18 and half at +19
0000042E  73A5                          jae     main_loop
00000430  FF060000                      inc     word ptr cam_x
00000434  EB9F                          jmp     main_loop
00000436                        key_rst:
00000436  803E000000                    cmp     byte ptr mode_rt, 0
