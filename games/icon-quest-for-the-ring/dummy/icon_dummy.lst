000004FB  8BD8                          mov     bx, ax
000004FD  8A870000                      mov     al, byte ptr [map_buf+bx]
00000501  32E4                          xor     ah, ah
00000503  B3C0                          mov     bl, STAMP_COUNT
00000505  F6F3                          div     bl                      ; AH = id mod 192
00000507  8AC4                          mov     al, ah
00000509  32E4                          xor     ah, ah

                                        ; DI → stamp in bank (char,attr pairs)
0000050B  BB1800                        mov     bx, STAMP_BYTES
0000050E  F7E3                          mul     bx
00000510  050000                        add     ax, offset bank_buf
00000513  8BF8                          mov     di, ax

                                        ; base row / col
00000515  8BC5                          mov     ax, bp
00000517  BB0600                        mov     bx, 6
0000051A  F7E3                          mul     bx
0000051C  83C002                        add     ax, ROW0
0000051F  8BC8                          mov     cx, ax                  ; row base

00000521  8BC6                          mov     ax, si
00000523  D1E0                          shl     ax, 1
00000525  83C001                        add     ax, COL0
00000528  8BD0                          mov     dx, ax                  ; col

0000052A  56                            push    si
0000052B  55                            push    bp
0000052C  33ED                          xor     bp, bp                  ; r within stamp
0000052E                        blit_r:
0000052E  83FD06                        cmp     bp, 6
00000531  7328                          jae     blit_stamp_done

00000533  8BC1                          mov     ax, cx
00000535  03C5                          add     ax, bp
00000537  83F819                        cmp     ax, 25
0000053A  7319                          jae     blit_r_next

0000053C  52                            push    dx
0000053D  BB2800                        mov     bx, 40
00000540  F7E3                          mul     bx                      ; clobbers DX
00000542  5A                            pop     dx
00000543  03C2                          add     ax, dx
00000545  D1E0                          shl     ax, 1
00000547  8BD8                          mov     bx, ax                  ; B800 offset

                                        ; already char,attr in bank
00000549  8B05                          mov     ax, word ptr [di]
0000054B  268907                        mov     word ptr es:[bx], ax
0000054E  8B4502                        mov     ax, word ptr [di+2]
00000551  26894702                      mov     word ptr es:[bx+2], ax

