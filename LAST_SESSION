        name=b[i+1:i+1+n]
        if not all(32<=c<127 for c in name): i+=1; continue
        s=name.decode()
        if sum(c.isalnum() or c in " _|'" for c in s)<len(s) or not any(c.isalpha() for c in s): i+=1; continue
        i=i+1+n
