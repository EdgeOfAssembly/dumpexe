            # context after string: look for B8 4E/59 (N/Y default)
            end = m.end()
            tail = b[end:end+16]
            default = None
            if len(tail) >= 3 and tail[0]==0xB8 and tail[2]==0x00:
                if tail[1] in (0x4E, 0x59, 0x79, 0x6E):  # N Y y n
                    default = chr(tail[1])
            found.append((m.start(), s.strip(), default, tail[:8].hex()))
    return found

