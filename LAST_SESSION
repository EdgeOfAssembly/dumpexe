# Render BA as linear B800 strip of various widths (in cells)
def render_b800_plane(data, cell_w, order='ac', scale=2, name='x'):
    # order ac: attr,char; ca: char,attr
    cells = []
    for i in range(0, len(data), 2):
        if order=='ac':
            attr, ch = data[i], data[i+1]
        else:
            ch, attr = data[i], data[i+1]
        cells.append((ch, attr))
    n = len(cells)
    if n % cell_w:
        # pad
        cells = cells + [(0,0)] * (cell_w - n%cell_w)
        n = len(cells)
    cell_h = n // cell_w
    # pixel buffer
    H, W = cell_h*8, cell_w*8
    pix = [[(0,0,0) for _ in range(W)] for _ in range(H)]
    for ci, (ch, attr) in enumerate(cells):
        cx, cy = ci % cell_w, ci // cell_w
        cell = render_cell(ch, attr)
        for r in range(8):
            for c in range(8):
                pix[cy*8+r][cx*8+c] = cell[r][c]
    ppm = OUT / f'{name}_{cell_w}x{cell_h}_{order}.ppm'
    write_ppm(ppm, pix, scale=scale)
    ppm_to_png(ppm)

# BA as fontsheet of 2x2 tiles (8 bytes = 4 pairs)
def tiles_2x2(data, order='ac'):
    tiles = []
    for i in range(0, len(data), 8):
        chunk = data[i:i+8]
        if len(chunk)<8: break
        cells = []
        for j in range(0,8,2):
            if order=='ac':
                attr, ch = chunk[j], chunk[j+1]
            else:
                ch, attr = chunk[j], chunk[j+1]
            cells.append((ch, attr))
        # cells 0,1 = row0; 2,3 = row1
        tiles.append(cells)
    return tiles

def render_tile_sheet(tiles, cols=16, scale=3, name='sheet'):
    rows = (len(tiles)+cols-1)//cols
    # each tile 16x16 px + 1 gap
    tw, th = 16+1, 16+1
    W, H = cols*tw, rows*th
    pix = [[(20,20,20) for _ in range(W)] for _ in range(H)]
    for ti, cells in enumerate(tiles):
        tx, ty = ti%cols, ti//cols
        for ci, (ch, attr) in enumerate(cells):
            cx, cy = ci%2, ci//2
            cell = render_cell(ch, attr)
            for r in range(8):
                for c in range(8):
                    pix[ty*th+cy*8+r][tx*tw+cx*8+c] = cell[r][c]
    ppm = OUT / f'{name}.ppm'
    write_ppm(ppm, pix, scale=scale)
    ppm_to_png(ppm)

# MAP composite
def render_map(mapdata, tiles, tile_w, index_fn, scale=2, name='map'):
    n = len(mapdata)
    if n % tile_w:
        print('skip non-divisible', name, n, tile_w)
        return
    tile_h = n // tile_w
    # each tile 16x16
    W, H = tile_w*16, tile_h*16
    pix = [[(0,0,0) for _ in range(W)] for _ in range(H)]
    oob = 0
    for i, b in enumerate(mapdata):
        idx = index_fn(b)
        tx, ty = i % tile_w, i // tile_w
        if idx < 0 or idx >= len(tiles):
