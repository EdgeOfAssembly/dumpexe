CGA = np.array([
    [0x00,0x00,0x00],[0x00,0x00,0xAA],[0x00,0xAA,0x00],[0x00,0xAA,0xAA],
    [0xAA,0x00,0x00],[0xAA,0x00,0xAA],[0xAA,0x55,0x00],[0xAA,0xAA,0xAA],
    [0x55,0x55,0x55],[0x55,0x55,0xFF],[0x55,0xFF,0x55],[0x55,0xFF,0xFF],
    [0xFF,0x55,0x55],[0xFF,0x55,0xFF],[0xFF,0xFF,0x55],[0xFF,0xFF,0xFF],
], dtype=np.uint8)

def glyph(ch):
    c = ch & 0xFF
    if c in (0xDB, 0xFE): return np.full(8, 0xFF, np.uint8)
    if c == 0xDC: return np.array([0,0,0,0,0xFF,0xFF,0xFF,0xFF], np.uint8)
    if c == 0xDF: return np.array([0xFF,0xFF,0xFF,0xFF,0,0,0,0], np.uint8)
    if c == 0xDD: return np.full(8, 0xF0, np.uint8)
    if c == 0xDE: return np.full(8, 0x0F, np.uint8)
    if c == 0xB0: return np.array([0x44,0x11,0x44,0x11,0x44,0x11,0x44,0x11], np.uint8)
    if c == 0xB1: return np.array([0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55], np.uint8)
    if c == 0xB2: return np.array([0xEE,0xBB,0xEE,0xBB,0xEE,0xBB,0xEE,0xBB], np.uint8)
    if c in (0x00, 0x20, 0xFF): return np.zeros(8, np.uint8)
    if c == 0x01: return np.array([0x18,0x3C,0x7E,0xFF,0xFF,0x7E,0x3C,0x18], np.uint8)
    # default filled if nonzero else empty-ish
    if c < 32:
        return np.full(8, 0xFF if c&1 else 0x00, np.uint8)
    # simple ascii-ish: filled rectangle
    return np.array([0x00,0x7E,0x7E,0x7E,0x7E,0x7E,0x7E,0x00], np.uint8)

def render_plane(data, cell_w, order='ac', scale=2):
    ncells = len(data)//2
    cells = []
    for i in range(0, len(data), 2):
        if order=='ac':
            attr, ch = data[i], data[i+1]
        else:
            ch, attr = data[i], data[i+1]
        cells.append((ch, attr))
    if ncells % cell_w:
        pad = cell_w - ncells % cell_w
        cells += [(0,0)]*pad
        ncells = len(cells)
    cell_h = ncells // cell_w
    H, W = cell_h*8, cell_w*8
    img = np.zeros((H, W, 3), np.uint8)
    for ci,(ch,attr) in enumerate(cells):
        cx, cy = ci % cell_w, ci // cell_w
        fg = CGA[attr & 0x0F]
        bg = CGA[(attr >> 4) & 0x07]
        g = glyph(ch)
        for r in range(8):
            bits = g[r]
            for c in range(8):
                on = (bits >> (7-c)) & 1
                img[cy*8+r, cx*8+c] = fg if on else bg
    if scale != 1:
        img = np.repeat(np.repeat(img, scale, 0), scale, 1)
    return img

