"""Clear stale traps, CONTINUE, catch INT21/07 char and pickup BP."""
import socket, time
from pathlib import Path

class C:
    def __init__(self):
        self.s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM)
        self.s.settimeout(30)
        self.s.connect('/tmp/dosbox-control.sock')
        self.buf=b''
        self._line()
    def _line(self):
        while b'\n' not in self.buf:
            self.buf+=self.s.recv(4096)
        line,_,self.buf=self.buf.partition(b'\n')
        return line.decode()
    def cmd(self, line, timeout=25):
        self.s.settimeout(timeout)
        self.s.sendall((line+'\n').encode())
        data=self.buf; self.buf=b''
        t0=time.time()
        while True:
            t=data.decode('utf-8','replace')
            if t.startswith(('OK TEXT','OK B800','OK SNAPSHOT','OK DIFF','OK TRACEBACK','OK INTRING','OK LIST')):
                if '\nEND\n' in t or t.rstrip().endswith('END'): return t
            elif t.endswith('\n') and t and not t.startswith(('OK TEXT','OK B800','OK SNAPSHOT','OK DIFF','OK TRACEBACK','OK INTRING','OK LIST')):
                return t.strip()
            if time.time()-t0>timeout: return t if t else 'ERR timeout'
            try: data+=self.s.recv(65536)
            except socket.timeout: return t if t else 'ERR timeout'
    def close(self):
        try: self.cmd('QUIT',1)
        except: pass
        self.s.close()

