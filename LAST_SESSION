out = Path('map_preview')
out.mkdir(exist_ok=True)

mapb = icon.joinpath('LA.MAP').read_bytes()
ba = icon.joinpath('BA.DAT').read_bytes()

# 8x8 1bpp: 8 bytes per glyph, row-major MSB left
def glyph(idx):
    idx = idx & 0xFF
    # try with and without high bit
    off = (idx & 0x7F) * 8
    if off + 8 > len(ba):
        off = (idx % (len(ba)//8)) * 8
    return ba[off:off+8]

def render_grid(cells, w, h, use_hibit_as_color=True, strip_hibit_index=True):
    # each cell 8x8 -> image w*8 x h*8
    W, H = w*8, h*8
    # RGB buffer
    pix = bytearray(W*H*3)
    for cy in range(h):
        for cx in range(w):
            v = cells[cy*w+cx]
            gi = (v & 0x7F) if strip_hibit_index else v
            g = glyph(gi)
            # fg/bg from high bit or fixed
            if use_hibit_as_color and (v & 0x80):
                fg, bg = (255,255,255), (0,0,0)
            else:
                fg, bg = (0,255,0), (0,0,0)
            # alternate: use low nibble of attr if 2-byte
            for row in range(8):
                bits = g[row] if row < len(g) else 0
                for col in range(8):
                    on = (bits >> (7-col)) & 1
                    color = fg if on else bg
                    x = cx*8+col
                    y = cy*8+row
                    i = (y*W+x)*3
                    pix[i:i+3] = bytes(color)
    return W, H, pix

