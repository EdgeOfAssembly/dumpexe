"""Render LA.MAP using BA.DAT as 8x8 1bpp glyphs (CGA-style)."""
from pathlib import Path
from collections import Counter

icon = Path('ICON')
out = Path('map_preview')
out.mkdir(exist_ok=True)

mapb = icon.joinpath('LA.MAP').read_bytes()
ba = icon.joinpath('BA.DAT').read_bytes()

# 8x8 1bpp: 8 bytes per glyph, row-major MSB left
def glyph(idx):
    idx = idx & 0xFF
    # try with and without high bit
    off = (idx & 0x7F) * 8
    if off + 8 > len(ba):
        off = (idx % (len(ba)//8)) * 8
    return ba[off:off+8]

def render_grid(cells, w, h, use_hibit_as_color=True, strip_hibit_index=True):
    # each cell 8x8 -> image w*8 x h*8
    W, H = w*8, h*8
    # RGB buffer
    pix = bytearray(W*H*3)
    for cy in range(h):
        for cx in range(w):
            v = cells[cy*w+cx]
            gi = (v & 0x7F) if strip_hibit_index else v
            g = glyph(gi)
            # fg/bg from high bit or fixed
            if use_hibit_as_color and (v & 0x80):
                fg, bg = (255,255,255), (0,0,0)
            else:
                fg, bg = (0,255,0), (0,0,0)
            # alternate: use low nibble of attr if 2-byte
            for row in range(8):
                bits = g[row] if row < len(g) else 0
                for col in range(8):
                    on = (bits >> (7-col)) & 1
                    color = fg if on else bg
                    x = cx*8+col
                    y = cy*8+row
                    i = (y*W+x)*3
                    pix[i:i+3] = bytes(color)
    return W, H, pix

def write_ppm(path, w, h, pix):
    with open(path,'wb') as f:
        f.write(f'P6\n{w} {h}\n255\n'.encode())
        f.write(bytes(pix) if not isinstance(pix, (bytes, bytearray)) else pix)

def write_png(path, w, h, pix):
    import subprocess, tempfile, os
    ppm = str(path)+'.ppm'
    write_ppm(ppm, w, h, pix)
    subprocess.run(['magick', ppm, str(path)], check=False)
    try: os.remove(ppm)
    except: pass

# Layouts
layouts = []
# raw byte as cell
for w in [40, 48, 64, 80, 32]:
    if len(mapb)%w==0:
        h=len(mapb)//w
        layouts.append((f'u8_{w}x{h}', w, h, list(mapb)))
# char of char+attr
for w in [40, 48, 64, 80, 32, 20, 24]:
    if len(mapb)%(2*w)==0:
        h=len(mapb)//(2*w)
        ch=list(mapb[0::2])
        at=list(mapb[1::2])
        layouts.append((f'ch_{w}x{h}', w, h, ch))
        # combine: char | (attr&0x80)
        comb=[(c & 0x7f) | (a & 0x80) for c,a in zip(ch,at)]
        layouts.append((f'chattr_{w}x{h}', w, h, comb))
        # attr as index
        layouts.append((f'at_{w}x{h}', w, h, at))

# Also try: map bytes as pairs (char,attr) with width from ADV 14 20 - no
# 40x25 screen region only - first 2000 bytes as char+attr
if len(mapb)>=2000:
    ch=list(mapb[0:2000:2]); at=list(mapb[1:2000:2])
    layouts.append(('screen_40x25_ch', 40, 25, ch))

# Score by "ink density" variance (structured maps have regional density)
def density_score(cells, w):
    h=len(cells)//w
    # tile diversity per 4x4 block
    if h<4 or w<4: return 0
    scores=[]
    for by in range(0,h-3,4):
        for bx in range(0,w-3,4):
            block=[cells[(by+dy)*w+(bx+dx)] for dy in range(4) for dx in range(4)]
            scores.append(len(set(block)))
    import statistics
    return statistics.mean(scores), statistics.pstdev(scores) if len(scores)>1 else 0

print('Layout scores (mean unique in 4x4, stdev):')
ranked=[]
for name,w,h,cells in layouts:
