def glyph2(idx):
    off = (idx & 0x7F) * 16
    if off+16 > len(ba): return bytes(16)
    return ba[off:off+16]

# 2bpp CGA: 2 bits per pixel, 4 pixels per byte
def render_2bpp(cells, w, h):
    W,H=w*8,h*8
    pix=bytearray(W*H*3)
    pal=[(0,0,0),(0,0,170),(0,170,0),(170,170,170)]
    for cy in range(h):
