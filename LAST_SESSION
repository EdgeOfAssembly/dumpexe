                    else:
                        color=(b1 >> (6-2*(col-4))) & 3
                    x=cx*8+col; y=cy*8+row
                    i=(y*W+x)*3
                    pix[i:i+3]=bytes(pal[color])
    return W,H,pix

for name,w,h,cells in [('u8_64x60',64,60,list(mapb)), ('ch_40x48',40,48,list(mapb[0::2]))]:
