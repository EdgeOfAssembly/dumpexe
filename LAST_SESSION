"""Decode LA.MAP with BA.DAT as 2x6 cell stamps (24 B), map index x*100+y."""
from pathlib import Path
import numpy as np
from PIL import Image
from collections import Counter

OUT = Path('/tmp/dumpexe/games/icon-quest-for-the-ring/map_preview')
ICON = Path('/tmp/dumpexe/games/icon-quest-for-the-ring/ICON')
BA = ICON.joinpath('BA.DAT').read_bytes()
BB = ICON.joinpath('BB.DAT').read_bytes()
LA = np.frombuffer(ICON.joinpath('LA.MAP').read_bytes(), dtype=np.uint8)

CGA = np.array([
    [0,0,0],[0,0,170],[0,170,0],[0,170,170],
    [170,0,0],[170,0,170],[170,85,0],[170,170,170],
    [85,85,85],[85,85,255],[85,255,85],[85,255,255],
    [255,85,85],[255,85,255],[255,255,85],[255,255,255],
], dtype=np.uint8)

def glyph(ch):
    c = ch & 0xFF
    if c in (0xDB, 0xFE): return np.full(8, 0xFF, np.uint8)
    if c == 0xDC: return np.array([0,0,0,0,255,255,255,255], np.uint8)
    if c == 0xDF: return np.array([255,255,255,255,0,0,0,0], np.uint8)
    if c == 0xDD: return np.full(8, 0xF0, np.uint8)
    if c == 0xDE: return np.full(8, 0x0F, np.uint8)
    if c == 0xB0: return np.array([0x44,0x11,0x44,0x11,0x44,0x11,0x44,0x11], np.uint8)
    if c == 0xB1: return np.array([0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55], np.uint8)
    if c == 0xB2: return np.array([0xEE,0xBB,0xEE,0xBB,0xEE,0xBB,0xEE,0xBB], np.uint8)
    if c in (0x00, 0x20, 0xFF): return np.zeros(8, np.uint8)
    if c == 0x01: return np.array([0x18,0x3C,0x7E,0xFF,0xFF,0x7E,0x3C,0x18], np.uint8)
    if c == 0x83: return np.array([0x0F]*4+[0xF0]*4, np.uint8)
    if c == 0x8B: return np.array([0xF0]*4+[0x0F]*4, np.uint8)
    if c == 0x7C: return np.full(8, 0x18, np.uint8)
    # box drawing approximations
    if c == 0xC4: return np.array([0,0,0,0xFF,0xFF,0,0,0], np.uint8)
    if c == 0xB3: return np.full(8, 0x18, np.uint8)
    return np.array([0x7E,0x7E,0x7E,0x7E,0x7E,0x7E,0x7E,0x00], np.uint8)

def cell_rgb(ch, attr):
    fg = CGA[attr & 0x0F]
    bg = CGA[(attr >> 4) & 0x07]
    g = glyph(ch)
    img = np.zeros((8,8,3), np.uint8)
    for r in range(8):
        bits = int(g[r])
        for c in range(8):
            img[r,c] = fg if (bits >> (7-c)) & 1 else bg
    return img

def parse_stamp(data, order='ca'):
    """24 bytes = 6 rows * 2 cells. Native B800 is char,attr (ca)."""
    cells = []  # 6 rows of 2 (ch,attr)
    for i in range(0, 24, 2):
        if order == 'ca':
            ch, attr = data[i], data[i+1]
        else:
            attr, ch = data[i], data[i+1]
        cells.append((ch, attr))
    # cells 0,1 row0; 2,3 row1; ...
    img = np.zeros((6*8, 2*8, 3), np.uint8)
    for idx, (ch, attr) in enumerate(cells):
        row, col = divmod(idx, 2)
        img[row*8:(row+1)*8, col*8:(col+1)*8] = cell_rgb(ch, attr)
    return img, cells

# Build stamps from BA
assert len(BA) == 2304
N = len(BA) // 24
print(f'BA stamps: {N} (24 bytes each)')

def build_stamps(bank, order):
    return [parse_stamp(bank[i*24:(i+1)*24], order)[0] for i in range(N)]

for order in ['ca', 'ac']:
    stamps = build_stamps(BA, order)
    # sheet
    cols = 16
    rows = (N + cols - 1) // cols
    gap = 2
    tw, th = 16+gap, 48+gap
    sheet = np.full((rows*th, cols*tw, 3), 40, np.uint8)
    for i, s in enumerate(stamps):
        r, c = divmod(i, cols)
        sheet[r*th:r*th+48, c*tw:c*tw+16] = s
    Image.fromarray(np.repeat(np.repeat(sheet, 2, 0), 2, 1)).save(OUT / f'BA_stamps_2x6_{order}.png')
    print('saved stamps', order)

# Map dimensions with stride 100
# index = x * 100 + y  → height 100, width = 3840//100 = 38
H_STRIDE = 100
W_MAP = len(LA) // H_STRIDE  # 38
print(f'MAP as {W_MAP} x {H_STRIDE} column-major (index=x*{H_STRIDE}+y), remainder {len(LA)%H_STRIDE}')

def map_at(x, y, stride=100):
    i = x * stride + y
    if 0 <= i < len(LA):
        return int(LA[i])
    return -1

# Also try row-major width 100
# index = y * 100 + x

def render_level(stamps, layout='x100+y', index_fn=lambda b: b & 0x7F, scale=1, name='level'):
    if layout == 'x100+y':
        w, h, stride = W_MAP, H_STRIDE, H_STRIDE
        def get(x,y):
            i = x*stride + y
            return LA[i] if i < len(LA) else 0
    elif layout == 'y100+x':
        # width 100, height 38
        w, h = H_STRIDE, W_MAP
        def get(x,y):
            i = y*100 + x
            return LA[i] if i < len(LA) else 0
    elif layout == 'w64':
        w, h = 64, len(LA)//64
        def get(x,y):
            return LA[y*64+x]
    elif layout == 'w40':
        w, h = 40, len(LA)//40
        def get(x,y):
            return LA[y*40+x]
    else:
        raise ValueError(layout)

    # each stamp 2 cells wide, 6 tall → pixel 16 x 48
    sw, sh = 16, 48
    img = np.zeros((h*sh, w*sw, 3), np.uint8)
    oob = 0
    for y in range(h):
        for x in range(w):
            b = int(get(x,y))
            idx = index_fn(b)
            if idx < 0 or idx >= len(stamps):
                oob += 1
                tile = np.full((sh,sw,3), [255,0,255], np.uint8)
            else:
                tile = stamps[idx]
            img[y*sh:(y+1)*sh, x*sw:(x+1)*sw] = tile
    if scale > 1:
        img = np.repeat(np.repeat(img, scale, 0), scale, 1)
    path = OUT / f'{name}.png'
    Image.fromarray(img).save(path)
    print(f'saved {path} {img.shape[1]}x{img.shape[0]} oob={oob} layout={layout}')
    return img

# Prefer ca (native B800 char,attr) and ac
for order in ['ca', 'ac']:
    stamps = build_stamps(BA, order)
    for layout in ['x100+y', 'y100+x', 'w64', 'w40']:
        for lo7 in [True, False]:
            fn = (lambda b: b & 0x7F) if lo7 else (lambda b: b)
            tag = 'lo7' if lo7 else 'raw'
            # skip raw if many oob
            render_level(stamps, layout=layout, index_fn=fn, scale=1,
