from pathlib import Path

def parse_dr(path):
    b = Path(path).read_bytes()
    i, ents = 0, []
    while i < len(b) - 2:
        n = b[i]
        if not (2 <= n <= 32):
            i += 1; continue
        name = b[i+1:i+1+n]
        if not all(32 <= c < 127 for c in name):
            i += 1; continue
        s = name.decode()
        if sum(c.isalnum() or c in " _|'" for c in s) < len(s) or not any(c.isalpha() for c in s):
            i += 1; continue
        i = i + 1 + n
        if i + 2 > len(b): break
        w, h = b[i], b[i+1]
        j = i + 2
        found = None
        while j < len(b) - 2:
            ln = b[j]
            if 2 <= ln <= 32:
                nm = b[j+1:j+1+ln]
                if all(32 <= c < 127 for c in nm):
                    ss = nm.decode()
                    if sum(c.isalnum() or c in " _|'" for c in ss) == len(ss) and any(c.isalpha() for c in ss):
                        found = j
                        break
            j += 1
        end = found if found else len(b)
        ents.append((s, w, h, b[i:end]))
        i = end
    return ents

def bake_cells(w, h, payload):
    """mask[w*h] + rest; 0x10=transparent. Char plane: after optional 01, 1 char per non-10."""
    body = payload[2:]
    mask = body[:w*h]
    rest = body[w*h:]
    ri = 1 if rest[:1] == b'\x01' else 0
    cells = []  # list of (ch, attr) or None
    for m in mask:
        if m == 0x10:
            cells.append(None)
        else:
            ch = rest[ri] if ri < len(rest) else 0xDB
            if ri < len(rest):
                ri += 1
            # attr: low nibble of mask often color; 0x0E yellow-ish for skeleton
            attr = m & 0x0F if m < 0x20 else (m & 0x0F)
            if attr == 0:
                attr = 0x07
            cells.append((ch, attr))
    return cells, ri, len(rest)

