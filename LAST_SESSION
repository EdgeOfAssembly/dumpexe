# BA on disk: attr,char — convert stamps to B800 order for matching

def ba_stamp_b800(idx: int) -> bytes:
    """Return 24 bytes as 6 rows × 2 cells in CHAR,ATTR order (B800 native)."""
    raw = BA[idx*24:(idx+1)*24]
    out = bytearray(24)
    for i in range(12):  # 12 cells
        attr, ch = raw[i*2], raw[i*2+1]
        out[i*2] = ch
