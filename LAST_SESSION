import re

def extract_prompts(path):
    b = Path(path).read_bytes()
    # length-prefixed Pascal-ish strings often start with count byte
    # also plain ASCII questions with ?
    found = []
    # pattern: printable question-like
    for m in re.finditer(rb'[\x20-\x7e]{10,80}', b):
        s = m.group().decode('ascii')
        low = s.lower()
        if any(k in low for k in (
            'do you', 'want to', 'enter the', 'press', '?', 'yes', 'no',
            'restart', 'advanced', 'quit', 'save', 'ready', 'continue',
            'illegal', 'original', 'ashamed', 'space', 'drive',
            'knowing', 'will you', 'are you', 'play an', 'level',
