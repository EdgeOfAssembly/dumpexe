    m,s = density_score(cells,w)
    # also nonzero ratio
    nz=sum(1 for c in cells if c)/len(cells)
    ranked.append((m, s, nz, name, w, h, cells))
ranked.sort(key=lambda t: (-t[0], -t[1]))
for m,s,nz,name,w,h,cells in ranked[:12]:
    print(f'  {name:20s} mean_uniq4={m:.2f} std={s:.2f} nz={nz:.2f}')

# Render top candidates + known 40x48 ch + 64x60
render_list = []
for m,s,nz,name,w,h,cells in ranked[:8]:
    render_list.append((name,w,h,cells))
# force some
for name,w,h,cells in layouts:
