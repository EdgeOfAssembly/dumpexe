# Simple palette: index -> RGB (distinct for low tiles, grayscale for high)
def pal(v):
    v &= 0xFF
    # bit7 as intensity/flag
    flag = v & 0x80
    t = v & 0x7F
    # CGA-ish-ish distinct colors for small tile ids
    base = [
        (0,0,0), (0,0,170), (0,170,0), (0,170,170),
        (170,0,0), (170,0,170), (170,85,0), (170,170,170),
        (85,85,85), (85,85,255), (85,255,85), (85,255,255),
        (255,85,85), (255,85,255), (255,255,85), (255,255,255),
    ]
    if t < 16:
        r,g,b = base[t]
    else:
        # hash-ish color
        r = (t * 37) & 255
        g = (t * 67) & 255
        b = (t * 97) & 255
    if flag:
        r = min(255, r + 40); g = min(255, g + 40)
    return r, g, b

def write_ppm(path, w, h, pixels):
    # pixels: list of (r,g,b) length w*h
    with open(path, 'wb') as f:
        f.write(f'P6\n{w} {h}\n255\n'.encode())
        f.write(bytes(c for p in pixels for c in p))

def decode_linear(data, width=64):
    assert len(data) % width == 0
    h = len(data) // width
    pix = [pal(data[y*width+x]) for y in range(h) for x in range(width)]
    return width, h, pix

# Also try RLE: if high bit set, next is count? or value is run of (v&7f)
# Common: byte B: if B<0x80 tile else (count=B-0x80, tile=next)
def try_rle_a(data, expected_tiles=None):
    i=0
    out=[]
    while i < len(data):
        b=data[i]; i+=1
        if b & 0x80:
            if i>=len(data): break
            cnt = (b & 0x7F) + 1
            tile = data[i]; i+=1
            out.extend([tile]*cnt)
        else:
            out.append(b)
    return bytes(out)

def try_rle_b(data):
    # pairs (count, tile)
    i=0; out=[]
    while i+1 < len(data):
        cnt, tile = data[i], data[i+1]; i+=2
        if cnt==0: cnt=256
        out.extend([tile]*cnt)
    return bytes(out)

