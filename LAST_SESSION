"""Render BA.DAT as ATTR,CHAR pairs (2x2 tiles) and composite LA.MAP."""
from pathlib import Path
import struct
import zlib

OUT = Path('/tmp/dumpexe/games/icon-quest-for-the-ring/map_preview')
BA = Path('/tmp/dumpexe/games/icon-quest-for-the-ring/ICON/BA.DAT').read_bytes()
BB = Path('/tmp/dumpexe/games/icon-quest-for-the-ring/ICON/BB.DAT').read_bytes()
LA = Path('/tmp/dumpexe/games/icon-quest-for-the-ring/ICON/LA.MAP').read_bytes()

# CGA 16-color palette (approx RGB)
CGA = [
    (0x00,0x00,0x00),(0x00,0x00,0xAA),(0x00,0xAA,0x00),(0x00,0xAA,0xAA),
    (0xAA,0x00,0x00),(0xAA,0x00,0xAA),(0xAA,0x55,0x00),(0xAA,0xAA,0xAA),
    (0x55,0x55,0x55),(0x55,0x55,0xFF),(0x55,0xFF,0x55),(0x55,0xFF,0xFF),
    (0xFF,0x55,0x55),(0xFF,0x55,0xFF),(0xFF,0xFF,0x55),(0xFF,0xFF,0xFF),
]

# Minimal CP437 → 8x8 1bpp for graphics block chars we care about + space
# We'll synthesize common block-drawing chars procedurally

def glyph_for(ch: int) -> list[int]:
    """Return 8 row bytes (MSB=left) for a CP437 char. Procedural for blocks."""
    rows = [0]*8
    c = ch & 0xFF
    # Full block
    if c in (0xDB, 0xFE):  # █
        rows = [0xFF]*8
    elif c == 0xDC:  # ▄ lower half
        rows = [0x00]*4 + [0xFF]*4
    elif c == 0xDF:  # ▀ upper half
        rows = [0xFF]*4 + [0x00]*4
    elif c == 0xDD:  # ▌ left half (sometimes)
        rows = [0xF0]*8
    elif c == 0xDE:  # ▐ right half
        rows = [0x0F]*8
    elif c == 0xB0:  # ░ light shade ~25%
        rows = [0x44,0x11,0x44,0x11,0x44,0x11,0x44,0x11]
    elif c == 0xB1:  # ▒ medium ~50%
        rows = [0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55]
    elif c == 0xB2:  # ▓ dark ~75%
        rows = [0xEE,0xBB,0xEE,0xBB,0xEE,0xBB,0xEE,0xBB]
    elif c == 0x00 or c == 0x20 or c == 0xFF:
        rows = [0x00]*8
    elif c == 0x01:  # smiling face-ish / filled diamond placeholder
        rows = [0x18,0x3C,0x7E,0xFF,0xFF,0x7E,0x3C,0x18]
    elif c == 0x83:  # â - use as diagonal pattern common in data
        rows = [0x01,0x02,0x04,0x08,0x10,0x20,0x40,0x80]
    elif c == 0x8B:  # ï
        rows = [0x80,0x40,0x20,0x10,0x08,0x04,0x02,0x01]
    elif c == 0x7C:  # |
        rows = [0x18]*8
    elif c == 0x48:  # H
        rows = [0x66,0x66,0x66,0x7E,0x66,0x66,0x66,0x00]
    elif c == 0x21:  # !
        rows = [0x18,0x18,0x18,0x18,0x18,0x00,0x18,0x00]
    elif c == 0x49:  # I
        rows = [0x3C,0x18,0x18,0x18,0x18,0x18,0x3C,0x00]
    elif c == 0x1F:  # black triangle down
        rows = [0x00,0xFF,0x7E,0x3C,0x18,0x00,0x00,0x00]
    else:
        # generic: use bits of char code as pattern so distinct
        rows = [((c*3+r*17)&0xFF) for r in range(8)]
        # make it more blocky
        rows = [0xFF if (c>>(r%8))&1 else 0x00 for r in range(8)]
        # better: checker from code
        v = c
        rows = []
        for r in range(8):
            row = 0
            for col in range(8):
                if (v >> ((r*3+col)&7)) & 1:
                    row |= (0x80>>col)
            rows.append(row)
    return rows

# Build full CP437-ish for letters using a tiny 5x7 font for ASCII 0x20-0x7E
# For non-block, use simple patterns

def render_cell(ch, attr, scale=1):
    """Return 8x8 RGB list-of-lists for one cell."""
    fg = CGA[attr & 0x0F]
    bg = CGA[(attr >> 4) & 0x07]  # blink bit ignored for bg (CGA)
    g = glyph_for(ch)
    pix = []
    for r in range(8):
        row = []
        b = g[r]
        for col in range(8):
            on = (b >> (7-col)) & 1
            row.append(fg if on else bg)
        pix.append(row)
    return pix

def write_ppm(path, pixels, scale=2):
    """pixels: H x W x (r,g,b)"""
    h = len(pixels)
    w = len(pixels[0])
    sh, sw = h*scale, w*scale
    lines = [f'P6\n{sw} {sh}\n255\n']
    path = Path(path)
    with open(path, 'wb') as f:
        f.write(f'P6\n{sw} {sh}\n255\n'.encode())
        for y in range(sh):
            row = pixels[y//scale]
            for x in range(sw):
                f.write(bytes(row[x//scale]))
    print('wrote', path, f'{sw}x{sh}')

def ppm_to_png(ppm_path):
    try:
        from PIL import Image
        im = Image.open(ppm_path)
        png = str(ppm_path).replace('.ppm','.png')
        im.save(png)
        print('png', png)
        return png
    except Exception as e:
        # try pnmtopng / convert
        import subprocess
        png = str(ppm_path).replace('.ppm','.png')
        for cmd in [
            ['pnmtopng', str(ppm_path)],
            ['convert', str(ppm_path), png],
            ['magick', str(ppm_path), png],
        ]:
            try:
                if cmd[0]=='pnmtopng':
                    with open(png,'wb') as out:
                        subprocess.check_call(cmd, stdout=out)
                else:
                    subprocess.check_call(cmd)
                print('png via', cmd[0], png)
                return png
            except Exception:
                continue
        print('no png converter', e)
        return None

# Parse BA as sequence of (attr, char) pairs  -- even=attr, odd=char
def pairs(data):
    return [(data[i], data[i+1]) for i in range(0, len(data), 2)]

ba_pairs = pairs(BA)
