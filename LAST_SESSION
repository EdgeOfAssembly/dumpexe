            ch, at = w&0xFF, (w>>8)&0xFF
            i = (r*bw+c)*2
            out[i]=ch; out[i+1]=at
    return bytes(out)

# Layout variants for BA stamp -> B800 bytes
def layouts(raw):
    """raw is 24 bytes from BA."""
    variants = {}
    # A: attr,char pairs row-major 2-wide -> swap to char,attr
    out=bytearray(24)
    for i in range(12):
        a,ch=raw[i*2],raw[i*2+1]
        out[i*2]=ch; out[i*2+1]=a
    variants['swap_rm'] = bytes(out)
    # B: already char,attr on disk
    variants['raw_as_ca'] = raw
    # C: attr,char but column-major (col0 all 6 rows then col1)
    # cells in raw order 0..11 as col-major: for col in 0..1 for row in 0..5
    out=bytearray(24)
    for idx in range(12):
        a,ch=raw[idx*2],raw[idx*2+1]
        # idx is col-major index?
        col, row = divmod(idx, 6)  # 2 cols of 6
        j = (row*2+col)*2
        out[j]=ch; out[j+1]=a
    variants['swap_cm'] = bytes(out)
    # D: char,attr col-major
    out=bytearray(24)
    for idx in range(12):
        ch,a=raw[idx*2],raw[idx*2+1]
        col, row = divmod(idx, 6)
        j = (row*2+col)*2
        out[j]=ch; out[j+1]=a
    variants['ca_cm'] = bytes(out)
    # E: row-major attr,char no swap used as-is for comparison to attr-first screen? no
    # F: pairs are char,attr but rows of 2: same as raw_as_ca
    # G: 6x2 but interleaved differently - words little-endian from attr,char means word=attr|ch<<8 vs ch|attr<<8
